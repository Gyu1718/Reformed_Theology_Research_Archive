{
  "id": "barth-content-packs-v1",
  "title": "Barth Church Dogmatics content pack manifest",
  "description": "권별 또는 대주제별 바르트 『교회교의학』 정리 파일을 자동 로드하기 위한 manifest입니다. GitHub Pages 정적 환경에서는 폴더 안의 임의 파일을 브라우저가 자동 탐색할 수 없으므로, 로더는 이 파일에 등록된 경로를 읽습니다. 미리 등록된 권별 파일은 나중에 해당 파일만 업로드해도 자동 적용됩니다.",
  "rules": {
    "packFilesAreLoadedInOrder": true,
    "curatedPacksReplaceGeneratedSubtopics": true,
    "missingOptionalPackIsIgnored": true,
    "newMajorThemePackRequiresManifestEntry": true,
    "recommendedPackShape": {
      "id": "string",
      "title": "string",
      "volume": "I/1 | I/2 | II/1 ...",
      "chapters": [
        {
          "ref": "CD I/1 §1",
          "chapterTitle": "string",
          "subtopics": [
            {
              "title": "string",
              "summary": "string",
              "note": "string",
              "argumentRole": "string",
              "reformedContrast": "string",
              "studyPrompt": "string"
            }
          ]
        }
      ]
    }
  },
